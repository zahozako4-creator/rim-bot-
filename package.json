{
  "name": "@rim/framework",
  "version": "1.0.0",
  "description": "Professional Facebook Messenger Framework",
  "author": {
    "name": "Fares"
  },
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "main": "./index.js",

  "scripts": {
    "start": "node index.js",
    "dev": "node --trace-warnings index.js",
    "debug": "node --inspect index.js",
    "restart": "npm run start",
    "clean": "node -e \"require('fs').rmSync('./cache',{recursive:true,force:true})\"",
    "logs": "node -e \"console.log('Logs Folder : ./logs')\"",
    "check": "npm audit",
    "update": "npm update"
  },

  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },

  "dependencies": {
    "axios": "^1.11.0",
    "chalk": "^5.6.2",
    "fca-unofficial": "^1.3.10",
    "fs-extra": "^11.3.2",
    "mime-types": "^3.0.1",
    "moment-timezone": "^0.6.0",
    "node-cache": "^5.1.2",
    "pino": "^9.7.0",
    "uuid": "^11.1.0"
  },

  "keywords": [
    "rim",
    "framework",
    "facebook",
    "messenger",
    "bot",
    "nodejs",
    "automation",
    "chatbot",
    "plugin-system",
    "middleware"
  ],

  "repository": {
    "type": "git",
    "url": "https://github.com/yourname/rim-framework.git"
  },

  "bugs": {
    "url": "https://github.com/yourname/rim-framework/issues"
  },

  "homepage": "https://github.com/yourname/rim-framework",

  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/yourname"
  }
}
